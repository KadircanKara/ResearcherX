# LLM — locally-run Ollama via its OpenAI-compatible API.
# Run Ollama on the host (macOS gets Metal GPU there; in-container is CPU-only)
# and pull a model first:  ollama pull gemma4
# The backend container reaches the host via host.docker.internal.
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
# Examples: gemma4, deepseek-r1:8b, llama3.1, qwen3 — anything in `ollama list`.
LLM_MODEL=gemma4
LLM_MAX_RETRIES=2

# Any OpenAI-compatible cloud provider also works, e.g. Groq:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# Preserved for future provider swaps; unused today.
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...

DATABASE_URL=postgresql+asyncpg://researcherx:researcherx@db:5432/researcherx
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

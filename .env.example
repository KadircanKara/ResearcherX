# LLM — Groq free tier via its OpenAI-compatible API.
# Get a free key at https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile
# SDK retry budget — absorbs Groq free-tier 429s with exponential backoff.
LLM_MAX_RETRIES=5

# Optional daily-quota failover: when the active provider keeps 429ing after
# SDK retries (Groq free tier = 100k tokens/day ≈ 8 full runs), calls rotate
# to the next entry. JSON list, order = priority. Recommended first fallback:
# Gemini Flash (free key: https://aistudio.google.com/apikey — generous RPD).
# OpenRouter only as a LAST resort with a pinned :free model (50 req/day
# unverified ≈ 2-3 runs; never use the openrouter/free auto-router — it picks
# models that reject system messages / response_format).
# LLM_FALLBACKS='[{"base_url":"https://generativelanguage.googleapis.com/v1beta/openai/","api_key":"AIza...","model":"gemini-2.0-flash"},{"base_url":"https://openrouter.ai/api/v1","api_key":"sk-or-v1-...","model":"meta-llama/llama-3.3-70b-instruct:free"}]'

DATABASE_URL=postgresql+asyncpg://researcherx:researcherx@db:5432/researcherx
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Long random string; X-API-Key with this value bypasses rate limits.
# Required when ENVIRONMENT=prod.
OWNER_API_KEY=
# ENVIRONMENT=prod   # uncomment on the production box (enables boot guards)
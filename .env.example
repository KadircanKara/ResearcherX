# LLM — Groq free tier via its OpenAI-compatible API.
# Get a key at https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile
# Groq free tier rate-limits (~30 req/min) — give the SDK 429-backoff headroom.
LLM_MAX_RETRIES=5

# Local alternative: host-run Ollama (GPU strongly recommended). Pull a model
# first (`ollama pull gemma4`); the backend container reaches the host via
# host.docker.internal. Any model from `ollama list` works.
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=gemma4
# LLM_MAX_RETRIES=2

# Preserved for future provider swaps; unused today.
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...

DATABASE_URL=postgresql+asyncpg://researcherx:researcherx@db:5432/researcherx
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
